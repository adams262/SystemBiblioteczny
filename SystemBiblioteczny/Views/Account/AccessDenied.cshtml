@{
    ViewData["Title"] = "Brak dostępu";
}

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-body py-5">
                    <i class="bi bi-shield-x text-danger" style="font-size: 4rem;"></i>
                    <h2 class="mt-3 text-danger">Brak dostępu</h2>
                    <p class="text-muted mt-2">
                        Nie masz uprawnień do wyświetlenia tej strony.<br />
                        Ta sekcja jest dostępna tylko dla bibliotekarzy.
                    </p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary me-2">
                        Strona główna
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">
                        Zaloguj się innym kontem
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
