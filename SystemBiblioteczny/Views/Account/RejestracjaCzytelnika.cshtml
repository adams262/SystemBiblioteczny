@model SystemBiblioteczny.Models.ViewModels.RejestracjaCzytelnikaViewModel
@{
    ViewData["Title"] = "Rejestracja czytelnika";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-person-plus"></i> Rejestracja czytelnika</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="RejestracjaCzytelnika" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Imie" class="form-label"></label>
                                <input asp-for="Imie" class="form-control" placeholder="Jan" />
                                <span asp-validation-for="Imie" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nazwisko" class="form-label"></label>
                                <input asp-for="Nazwisko" class="form-control" placeholder="Kowalski" />
                                <span asp-validation-for="Nazwisko" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="jan@email.pl" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        

                        <div class="mb-3">
                            <label asp-for="Haslo" class="form-label"></label>
                            <input asp-for="Haslo" class="form-control" placeholder="min. 6 znaków" />
                            <span asp-validation-for="Haslo" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PotwierdzHaslo" class="form-label"></label>
                            <input asp-for="PotwierdzHaslo" class="form-control" placeholder="powtórz hasło" />
                            <span asp-validation-for="PotwierdzHaslo" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100">
                            Utwórz konto czytelnika
                        </button>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    Masz już konto? <a asp-action="Login">Zaloguj się</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
