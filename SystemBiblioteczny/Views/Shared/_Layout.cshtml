<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – System Biblioteczny</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary border-bottom">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-book me-1"></i> Biblioteka
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Strona główna</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Ksiazki" asp-action="Index">Książki</a>
                        </li>
                        @if (User.IsInRole("Bibliotekarz"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Autorzy" asp-action="Index">Autorzy</a>
                            </li>
                        }
                        @if (User.IsInRole("Bibliotekarz"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Kategorie" asp-action="Index">Kategorie</a>
                            </li>
                        }
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Czytelnik"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Wypozyczenia" asp-action="MojeWypozyczenia">
                                    Moje Wypozyczenia
                                </a>
                            </li>
                        }
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Bibliotekarz"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Uzytkownicy" asp-action="Index">Panel Zarzadzania</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @User.Identity.Name
                                    @if (User.IsInRole("Bibliotekarz"))
                                    {
                                        <span class="badge bg-warning text-dark ms-1">Bibliotekarz</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-primary ms-1">Czytelnik</span>
                                    }
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right me-1"></i> Wyloguj się
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Zaloguj się
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="RejestracjaCzytelnika">
                                    <i class="bi bi-person-plus me-1"></i> Rejestracja
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-5 py-3 bg-light border-top">
        <div class="container text-center text-muted">
            <small>&copy; @DateTime.Now.Year System Biblioteczny</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
