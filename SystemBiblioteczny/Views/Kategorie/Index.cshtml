@model IEnumerable<SystemBiblioteczny.Models.Kategoria>

<h1>Kategorie</h1>

@* Alerty powinny być poza tabelą, najlepiej przed nią *@
@if (TempData["BladKategoria"] != null)
{
    <div class="alert alert-danger">@TempData["BladKategoria"]</div>
}
@if (TempData["SukcesKategoria"] != null)
{
    <div class="alert alert-success">@TempData["SukcesKategoria"]</div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Dodaj kategorię</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nazwa kategorii</th>
            <th style="width: 150px;">Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="align-middle">@item.Nazwa</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@item.KategoriaId" class="btn btn-danger btn-sm">Usuń</a>
                </td>
            </tr>
        }
    </tbody>
</table>