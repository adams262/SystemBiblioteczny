@model SystemBiblioteczny.Models.Ksiazka

<h1>Szczegóły książki</h1>

<div class="card">
    <div class="card-body">

        <h3>@Model.Tytul</h3>

        <p><strong>ISBN:</strong> @Model.ISBN</p>

        <p><strong>Rok wydania:</strong> @Model.RokWydania</p>

        <p><strong>Wydawnictwo:</strong> @Model.Wydawnictwo</p>

        <p><strong>Kategoria:</strong> @Model.Kategoria?.Nazwa</p>

        <p>
            <strong>Autor:</strong>

            @string.Join(", ",
                Model.KsiazkaAutorzy.Select(a =>
                    a.Autor.Imie + " " + a.Autor.Nazwisko))
        </p>

        

    </div>
</div>

<br />



<a asp-action="Index"
   class="btn btn-secondary">
    Powrót
</a>