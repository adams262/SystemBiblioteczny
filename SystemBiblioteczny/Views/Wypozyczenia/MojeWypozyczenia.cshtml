@model IEnumerable<SystemBiblioteczny.Models.Wypozyczenie>

<h1>Moje Wypożyczone Książki</h1>

@if (TempData["Sukces"] != null)
{
    <div class="alert alert-success">@TempData["Sukces"]</div>
}
@if (TempData["Blad"] != null)
{
    <div class="alert alert-danger">@TempData["Blad"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Aktualnie nie masz wypożyczonych żadnych książek.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Tytuł książki</th>
                <th>Data wypożyczenia</th>
                <th>Termin zwrotu</th>
                <th>Status</th>
                <th>Przedłużenia</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Egzemplarz.Ksiazka.Tytul</strong></td>
                    <td>@item.DataWypozyczenia.ToString("dd.MM.yyyy")</td>
                    <td>@item.PlanowanyZwrot.ToString("dd.MM.yyyy")</td>
                    <td>
                        @if (item.Status == SystemBiblioteczny.Models.StatusWypozyczenia.Aktywne)
                        {
                            <span class="badge bg-primary">Aktywne</span>
                        }
                        else if (item.Status == SystemBiblioteczny.Models.StatusWypozyczenia.Zwrocone)
                        {
                            <span class="badge bg-secondary">Zwrócone</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Przeterminowane</span>
                        }
                    </td>
                    <td>@item.LiczbaPrzedluzen / 2</td>
                    <td>
                        @* Czytelnik może sam przedłużyć książkę, jeśli jest aktywna i limit nie minął *@
                        @if (item.Status == SystemBiblioteczny.Models.StatusWypozyczenia.Aktywne && item.LiczbaPrzedluzen < 2)
                        {
                            <a asp-action="Przedluz" asp-route-id="@item.WypozyczanieId" class="btn btn-outline-warning btn-sm">
                                Przedłuż o 14 dni
                            </a>
                        }
                        else if (item.Status == SystemBiblioteczny.Models.StatusWypozyczenia.Aktywne)
                        {
                            <span class="text-muted small">Brak możliwości przedłużenia</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}